# ============================================================
# NexaSense AI Assistant — Environment Configuration Template
# Copy this to .env and fill in your values
# ============================================================

# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────
# Docker: use service name "postgres" as host
# Local:  use "localhost"
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/nexasense

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ─── ChromaDB ─────────────────────────────────────────────────
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_URL=http://chroma:8000
CHROMA_COLLECTION=nexasense

# ─── LLM API Keys ─────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# ─── Authentication ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate-a-64-byte-random-hex-string
JWT_REFRESH_SECRET=generate-a-different-64-byte-random-hex-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Admin Seeding ────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-to-a-secure-12-char-password!
ADMIN_FORCE_RESET=false

# ─── File Upload ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=20971520

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Rate Limiting ────────────────────────────────────────────
DAILY_QUERY_LIMIT=100

# ─── Razorpay Payments ────────────────────────────────────────
# Test keys:  rzp_test_...
# Live keys:  rzp_live_...
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Comma-separated list of allowed origins
# FRONTEND_URL=https://yourdomain.com

# ─── Razorpay Webhook (REQUIRED FOR BILLING) ──────────────
# Found in Razorpay Dashboard > Settings > Webhooks
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Frontend Build (Docker only) ─────────────────────────────
# Must match RAZORPAY_KEY_ID — injected as Vite build arg
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id
# Production: https://yourdomain.com/api
# Development: http://localhost:3000/api
VITE_API_URL=https://rajakumar-nexasense-ai.online/api
VITE_ALLOWED_FILE_TYPES=.pdf,.docx,.txt,.html

# ─── Observability (Optional for Prometheus/Grafana) ────────
PROM_SCRAPE_INTERVAL=15s
GRAFANA_ADMIN_PASSWORD=admin
# EXPOSE_METRICS_ENDPOINT=true